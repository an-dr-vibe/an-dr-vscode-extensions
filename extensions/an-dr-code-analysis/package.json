{
	"name": "an-dr-code-analysis",
	"displayName": "Code Analysis",
	"version": "0.1.0",
	"publisher": "an-dr",
	"author": {
		"name": "an-dr",
		"email": "mail@agramakov.me"
	},
	"description": "Static code analysis: call graphs, file dependencies, and component dependencies.",
	"categories": [
		"Other"
	],
	"homepage": "https://github.com/an-dr/an-dr-vscode-extensions/tree/main/extensions/an-dr-code-analysis",
	"repository": {
		"type": "git",
		"url": "https://github.com/an-dr/an-dr-vscode-extensions.git"
	},
	"license": "MIT",
	"engines": {
		"vscode": "^1.90.0"
	},
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "an-dr-code-analysis",
					"title": "Code Analysis",
					"icon": "$(graph)"
				}
			]
		},
		"views": {
			"an-dr-code-analysis": [
				{
					"type": "webview",
					"id": "an-dr-code-analysis.panel",
					"name": "Code Analysis"
				}
			]
		},
		"commands": [
			{
				"command": "an-dr-code-analysis.selectCompileCommands",
				"title": "Select compile_commands.json",
				"category": "Code Analysis"
			},
			{
				"command": "an-dr-code-analysis.selectTsconfig",
				"title": "Select tsconfig (cross-project override)",
				"category": "Code Analysis"
			}
		],
		"configuration": {
			"title": "An-Dr Code Analysis",
			"properties": {
				"an-dr-code-analysis.analysis.maxDepth": {
					"type": "number",
					"default": 5,
					"minimum": 1,
					"maximum": 8,
					"description": "Hard cap on depth in sidebar."
				}
			}
		}
	},
	"scripts": {
		"compile": "webpack --mode development",
		"build": "webpack --mode production",
		"build:dev": "webpack --mode development",
		"watch": "webpack --mode development --watch",
		"package": "vsce package --no-dependencies",
		"install-ext": "npm run build && vsce package --no-dependencies && code --install-extension an-dr-code-analysis-0.1.0.vsix",
		"test": "jest",
		"test:coverage": "jest --coverage"
	},
	"devDependencies": {
		"@types/d3": "^7.4.3",
		"@types/jest": "^30.0.0",
		"@types/node": "^18.0.0",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.9.2",
		"jest": "^30.4.2",
		"ts-jest": "^29.4.11",
		"ts-loader": "^9.5.1",
		"typescript": "^5.4.5",
		"webpack": "^5.91.0",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"d3": "^7.9.0"
	}
}

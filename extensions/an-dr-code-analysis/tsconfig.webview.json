{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"sourceMap": true
	},
	"include": ["webview-src/**/*", "shared/**/*"],
	"exclude": ["node_modules", "out", "src"]
}
